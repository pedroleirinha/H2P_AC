 266 00E4 05 48	    BHS	while_end       ; 0 >= m
 267           	
 268 00E6 22 80	    ADD	r2, r2, r0
 269 00E8 04 60	    MOV r4, #0
 270 00EA 33 92	    ADC r3, r3, r4
 271           	    
