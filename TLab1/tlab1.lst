 255           	; >> Função UMULL <<
 256           	; Tipo: - FOLHA -
 257           	; Parametros de entrada:
 258           	;   uint16_t v --> r0
 259           	;   uint16_t k --> r1
 260           	;
 261           	; variaveis locais:
