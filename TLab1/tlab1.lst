 233           	; >> Função UMULL <<
 234           	; Tipo: - FOLHA -
 235           	; Parametros de entrada:
 236           	;   uint16_t v --> r0
 237           	;   uint16_t k --> r1
 238           	;
 239           	; variaveis locais:
 240           	;   uint16_t p -------> r2  ; Bits menos significativos
 241           	;   uint16_t p -------> r3  ; Bits mais significativos
 242           	;
 243           	; Parametros de saida:
 244           	;   uint32_t p -------> r0, r1
 245           	;
 246           	umull:
 247 00D0 04 24	    PUSH R4
 248           	
 249           	                        ; compare_menor dos registos
 250 00D2 80 B8		CMP r0, r1
 251 00D4 03 48		BHS before_while    ; aqui o r1 é menor que o r0
 252           	
 253           	                        ; faz troca
 254 00D6 03 B0	    MOV r3, r0          ; mete o M no r4
 255 00D8 80 B0	    MOV r0, r1          ; mete no M o m
 256 00DA 81 B1	    MOV r1, r3          ; mete no m o r4  (que é o M)
 257           	
 258           	before_while:
 259 00DC 04 60	    MOV r4, #0
 260           	    
 261 00DE 02 60	    MOV r2, #0          ; accumulado/p [0]
