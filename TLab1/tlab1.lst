 272 00EA 80 B8		CMP r0, r1
 273 00EC 03 48		BHS before_while    ; aqui o r1 é menor que o r0
 274           	
 275           	                        ; faz troca
 276 00EE 03 B0	    MOV r3, r0          ; mete o M no r4
 277 00F0 80 B0	    MOV r0, r1          ; mete no M o m
 278 00F2 81 B1	    MOV r1, r3          ; mete no m o r4  (que é o M)
 279           	
