;>>Função scale_value<<
;  Tipo: - NÃO FOLHA -
; Parametros de entrada:
;   uint16_t v-------> r0
;   uint08_t K-------> r1
;   uint08_t S-------> r2
;
; variáveis locais:
;   uint32_t prod----> r4:r5
;   uint16_t k_ext---> r6
;   uint16_t prod_s--> r7
;   uint16_t prod_c--> r8
;
; Parametros de saída:
; uint16_t--------->   r0:r1
;




scale_value:

	push lr
	push r4
	push r5
	push r6
	push r7
	

	mov r4, r0		;para guardar v em registo seguro
	mov r5, r1		;para guardar k em registo seguro
	mov r6, r2		;para guardar s em registo seguro

	;mov r2, #0xff   ;guardo em r2 o valor 0 que servirá para extender o k para 16 bits
	;and r1, r1, r2  ; guardo em r1 o valor de k_ext já com 16 bits

	bl umull

	mov r2, #0		; guardo em r2 o valor temporário 0

	cmp r6, r2		; comparo s com 0
	beq scale_value_end


	mov r2, r6		; guardo em r2 o s extendido e r2 = s (shift count)
	mov r3, #1		; guardo em r3 o valor 1
	; r4   se exceder r3 no carry usamos r4 para guardar o resto
	mov r5, #1
	mov r7, #0
shift_loop_left:

	cmp r5, r2		; compara 1 com s
	bhs shift_left_end  ; se 1 for maior ou igual salta para fora do loop
	lsl r3, r3, #1  ; desloca o valor de r3 1 bit para a esquerda (multiplica por 2)
	adc r4, r4, r7	  
	sub r2, r2, #1  ; decrementa o r2 que é o contador

	b	shift_loop_left

shift_left_end:

	add r0, r0, r3  ; faz a soma da parte baixa do prod com 
	adc r1, r1, r7



	mov r2, r6       ; r2 = s (número de bits a deslocar)
    mov r4, #0       ; 

shift_loop_rigth:

	cmp r4, r2
    bhs scale_value_end  ; se r4 >= s, termina loop

    
    lsr r1, r1, #1       ; 
    rrx r0, r0           ; 

    sub r2, r2, #1       ; incrementa contador
    b shift_loop_rigth


scale_value_end:

    mov  r1, #VAL_MIN
    mov r2, r0

    bl clamp_value    
    ;retorno já esta no r0

    pop r7
    pop r6
    pop r5
    pop r4 
    pop PC




