;>>Função umull <<
;  Tipo: - NÃO FOLHA -
; Parametros de entrada:
;   uint16_t v-----------> r0
;   uint16_t k_ext-------> r1
;
; variáveis locais:
;   uint16_t p_baixa-------------> r2
;   uint16_t p_alta-------------> r3
;   variavel temporaria---------> r4
;
;  
;
; Parametros de saída:
; uint32_t---------------> r0:r1
;
;prod = umull( v, k_ext )
;
;uint16_t p = 0;
;if ( M != 0 ) {
;while ( m > 0 ) {
;p = p + M;
;m--;
;}
;}



umull:

	push r4
	mov r4, #0		; variável temporária com valor 0

	cmp r0, r4		; compara v com 0
	beq	umull_end	; se k for igual a 0 salta para o fim da função


	cmp r0, r1		; comparo v com k_ext
	bhs pre_while	; se v for maior que k_ext salta para o while


	mov r2, r0		;guarda em r2 o v
	mov r0, r1		;guarda em r0 o k_ext porque é maior que v
	mov r1, r2		;guarda em r1 o v


pre_while:

	mov r2, #0		; parte baixa de p a 0
	mov r3, #0		; parte alta de p a 0

umull_while:

	
	cmp r4, r1		; compara 0 com v ou k_ext dependendo de qual for menor
	bhs umull_end	;se 0 for maior ou igual a k_ext ou v salta 

	add r2, r2, r0  ; soma na parte baixa de p com v ou k_ext

	adc r3, r3, r4  ; soma na parte alta de p com 0 e dependendo se ouve overflow na parte baixa faz soma com carry

	sub r1, r1, #1  ; dimui o contador( k_ext ou v) em 1 
	b	umull_while
	

umull_end:

	pop r4

	mov r0, r2	    ; guarda em r0 a parte baixa de p
	mov r1, r3		; guarda em r1 a parte alta de p
	mov pc, lr
 
 
