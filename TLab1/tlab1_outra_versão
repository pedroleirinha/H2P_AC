;>>Função clamp_value<<
;  Tipo: - FOLHA -
; Parametros de entrada:
;   uint16_t val-------> r0
;   uint16_t min-------> r1
;   uint16_t max-------> r2
;
; variáveis locais:
;   - Não tem -
;
; Parametros de saída:
;   uint16_t--------->   r0
;




clamp_value:            ;criámos uma label com o nome da função;
    cmp r0, r1          ;comparámos o val com o min;
    bhs clamp_else      ; usámos o higher or same para saltar apenas quando  (val < min) for falso ou seja val >= min for verdadeiro;
    mov r0, r1          ; movemos o valor guardado em min para o val;
    b   clamp_end       ;fizemos um branch para saltar para o final da funçao;

clamp_else:             ;criámos uma label para o else da função;
    cmp r2, r0          ;comparámos  max com o val;
    bhs clamp_end       ; se a condição (max >= val) for verdadeira ou (val > max ) falsa ele salta para o fim da função;
    mov r0, r2          ;movemos o valor guardado em max para o val;
clamp_end:              ;criámos uma label para o fim da função;
    mov pc, lr




