;
; >> Função BUILD_SEQUENCE <<
; Tipo: - NAO FOLHA -
; Parametros de entrada:
;   uint16_t v_init ---> r0
;   uint16_t v[] --------> r1
;   uint8_t k[] ---------> r2
;   uint8_t s[] ---------> r3
;
; variaveis locais:
;   uint16_t i -------> r4
;
; Parametros de saida:
;   uint16_t ---------> r0
;

build_sequence:

	push lr
	push r4
	push r5
	push r6
	push r7


	mov r4, #0		;mover para i o valor 0

	str r0, [r1]	;guardar em memoria o valor da posicao incial de v[] em r0 


	; movemos para os seguintes registos r1,r2,r3 pars durante a funcao while ter livre os registos de r1 a r3

	mov r5, r1 		; mover para r5 o valor de v[] 
	mov r6, r2		; mover para r6 o valor de k[]
	mov r7, r3		; mover para r7 o valor de s[]


build_sequence_while:

	mov r1, #0			 ;variavel local com o valor 0
	ldrb r2, [r7, r4]    ;carrega em r2 o valor de s[i]

	cmp r1, r2
	beq build_sequence_end	;se s[i] for igual a 0 quero que salte para fora

	ldrb r1, [r6, r4]		; carrega o valor de k[i] em r1
	ldrb r2, [r7, r4]		; carrega o valor de s[i] em r2

	bl	scale_value			

	add r4, r4, #1			; incrementa 1 em i 
	lsl r1, r4, #1			; como cada elemento ocupa 2 bytes  tivemos de fazer um ajuste para poder saltar cada elemento

	str r0, [r5, r1]		; v[i + 1]

	

	b	build_sequence_while


build_sequence_end:

	add r0, r4, #1		;retorna i + 1

	pop r7
	pop r6
	pop r5
	pop r4
	pop pc






